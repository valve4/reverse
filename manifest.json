{
  "manifest_version": 3,
  "name": "Reverse — Flight Fare Finder",
  "version": "0.1.0",
  "description": "Find cheaper flights by searching reverse routes, split legs, and nearby airports. Sorts all options by price automatically.",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://api.amadeus.com/*",
    "https://api.skyscanner.net/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Reverse — Flight Fare Finder"
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
